# Multi-Hook frontend env vars — TEMPLATE (safe to commit)
# Copy values into app/.env (which IS gitignored). Do NOT put real keys here.

# ── RPC ────────────────────────────────────────────────────────────────────────
# Optional Helius devnet API key. When set, the dApp routes RPC reads/writes
# through Helius for higher rate limits + better simulation latency.
# When unset, falls back to https://api.devnet.solana.com.
#   1. Sign up at https://helius.dev (free tier)
#   2. Generate a devnet key
#   3. Restrict it to referrer: yonkoo11.github.io in the Helius dashboard
#   4. Paste it below in your .env
VITE_HELIUS_KEY=

# ── MAINNET MINT (enables the analytics section) ───────────────────────────────
# The Token-2022 mint address (mainnet) protected by your MetaHook deployment.
# When set, the dApp renders the Live Mint Analytics section pulling data
# from GoldRush + Birdeye + Dune. Unset → analytics shows configure-to-activate.
VITE_MAINNET_MINT=

# ── GoldRush (Covalent) ────────────────────────────────────────────────────────
# Free tier: https://goldrush.dev → API Keys
# Restrict the key to your dApp domain in the GoldRush dashboard.
VITE_GOLDRUSH_KEY=

# ── Birdeye ────────────────────────────────────────────────────────────────────
# Free tier: https://docs.birdeye.so/docs/authentication
# Restrict the key to your dApp domain in the Birdeye dashboard.
VITE_BIRDEYE_KEY=

# ── Dune ───────────────────────────────────────────────────────────────────────
# Public Dune dashboard URL (no key needed for embed; the dashboard itself
# must be set to public visibility on Dune).
# Once you publish dune/audit_events.sql as a Dune query and pin it to a
# dashboard, paste the dashboard's "embed" URL here.
VITE_DUNE_DASHBOARD_URL=
