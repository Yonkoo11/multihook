{
  "compilerOptions": {
    "target": "ES2018",
    "module": "esnext",
    "jsx": "react",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "noEmit": true,
    "allowJs": false,
    "incremental": true,
    "lib": ["dom", "esnext"]
  },
  "include": ["src/**/*"]
}
